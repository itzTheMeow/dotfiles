#!/usr/bin/env bash

export AWS_ACCESS_KEY_ID={{ onepasswordRead "op://Private/Backblaze/Application Keys/xela-codes-nas-id" }}
export AWS_SECRET_ACCESS_KEY="op://Private/Backblaze/Application Keys/xela-codes-nas-applicationKey"

export RESTIC_COMPRESSION=max
export RESTIC_REPOSITORY=s3:s3.us-east-005.backblazeb2.com/xela-codes-nas
export RESTIC_PASSWORD="op://Private/Backblaze Restic Repo/password"

LOG_FILE="/tmp/restic_$(date +"%Y-%m-%d_%H-%M-%S").log"
MOUNTPOINT="/mnt/pcloud"

# log into 1password
eval $(op signin)

# make sure mountpoint exists
mkdir -p "$MOUNTPOINT"

# Start rclone in background if not already mounted. Capture PID so we can clean up.
RC_RCLONE_PID=""
if ! mountpoint -q "$MOUNTPOINT"; then
  # Start rclone in background and redirect its logs to the same log file
  nohup rclone mount pcloud: "$MOUNTPOINT" --read-only --buffer-size 64M --transfers 16 --checkers 8 --dir-cache-time 5m >>"$LOG_FILE" 2>&1 &
  RC_RCLONE_PID=$!

  # Wait up to 30 seconds for the mount to appear
  TIMEOUT=30
  SECONDS_WAIT=0
  until mountpoint -q "$MOUNTPOINT" || [ $SECONDS_WAIT -ge $TIMEOUT ]; do
    sleep 1
    SECONDS_WAIT=$((SECONDS_WAIT+1))
  done

  if ! mountpoint -q "$MOUNTPOINT"; then
    echo "rclone mount failed to appear within ${TIMEOUT}s, aborting" >&2
    kill $RC_RCLONE_PID 2>/dev/null || true
    exit 1
  fi

  echo "rclone mounted" >&2
fi

# Cleanup function: unmount and kill rclone if we started it.
cleanup() {
  if [ -n "$RC_RCLONE_PID" ]; then
    # Kill rclone first to stop any ongoing operations
    kill $RC_RCLONE_PID 2>/dev/null || true
    # Give it a moment to exit cleanly
    sleep 1
  fi
  
  if mountpoint -q "$MOUNTPOINT"; then
    # Wait a bit for any file operations to complete
    sleep 2
    # Try to unmount gracefully; fallback to lazy unmount
    fusermount -u "$MOUNTPOINT" 2>/dev/null || umount -l "$MOUNTPOINT" 2>/dev/null || true
  fi
}

# Ensure cleanup runs on exit or interruption
trap cleanup EXIT INT TERM

echo "backing up..." >&2
# Use restic's JSON lines mode: JSON (machine) logs are written to stdout and
# progress output is sent to stderr. Redirect stdout to the log file so the
# JSON-lines are captured, while leaving stderr alone so the progress bar shows
# up on the user's terminal.
op run -- restic backup --json "$MOUNTPOINT" "$@" 2>&1 | while IFS= read -r line; do
  # Try to parse as JSON
  if message_type=$(echo "$line" | jq -r '.message_type // empty' 2>/dev/null); then
    case "$message_type" in
      status)
        # Extract status fields
        percent=$(echo "$line" | jq -r '.percent_done // 0')
        files_done=$(echo "$line" | jq -r '.files_done // 0')
        total_files=$(echo "$line" | jq -r '.total_files // 0')
        bytes_done=$(echo "$line" | jq -r '.bytes_done // 0')
        total_bytes=$(echo "$line" | jq -r '.total_bytes // 0')
        seconds_remaining=$(echo "$line" | jq -r '.seconds_remaining // 0')
        error_count=$(echo "$line" | jq -r '.error_count // 0')
        
        # Convert bytes to human readable
        bytes_done_h=$(numfmt --to=iec-i --suffix=B "$bytes_done" 2>/dev/null || echo "${bytes_done}B")
        total_bytes_h=$(numfmt --to=iec-i --suffix=B "$total_bytes" 2>/dev/null || echo "${total_bytes}B")
        
        # Format progress message (only to terminal, not log file)
        percent_int=$(printf "%.1f" "$(echo "$percent * 100" | bc -l 2>/dev/null || echo 0)")
        printf "\r[%s%%] %s/%s files, %s/%s, ~%ds remaining" \
          "$percent_int" "$files_done" "$total_files" "$bytes_done_h" "$total_bytes_h" "$seconds_remaining" >&2
        ;;
      error)
        # Extract error details
        error_msg=$(echo "$line" | jq -r '.error.message // "unknown error"')
        during=$(echo "$line" | jq -r '.during // ""')
        item=$(echo "$line" | jq -r '.item // ""')
        
        # Print to stderr
        echo -e "\nError: $error_msg" >&2
        [ -n "$during" ] && echo "  During: $during" >&2
        [ -n "$item" ] && echo "  Item: $item" >&2
        
        # Log to file
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] ERROR: $error_msg" >>"$LOG_FILE"
        [ -n "$during" ] && echo "  During: $during" >>"$LOG_FILE"
        [ -n "$item" ] && echo "  Item: $item" >>"$LOG_FILE"
        ;;
      summary)
        # Extract summary info and print to both terminal and log
        summary_output=$(echo "$line" | jq -r 'to_entries | map("\(.key): \(.value)") | .[]')
        echo "" >&2  # Clear progress line
        echo "Backup complete!" >&2
        echo "$summary_output" >&2
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Backup Summary:" >>"$LOG_FILE"
        echo "$summary_output" >>"$LOG_FILE"
        ;;
      *)
        # Unknown message type, log to both terminal and file
        echo "$line" >&2
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] $line" >>"$LOG_FILE"
        ;;
    esac
  else
    # Not JSON or failed to parse, treat as plain text - log to both
    echo "$line" >&2
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $line" >>"$LOG_FILE"
  fi
done

echo "" >&2  # Final newline after progress

if command -v ntfy &>/dev/null; then
  NTFY_TOPIC="$NTFY_TOPIC-backups" ntfy publish -t "Restic Backup Complete" "$(cat "$LOG_FILE")"
fi
